---
import Layout from '../layouts/Layout.astro';

// 1. Viteの標準機能でMarkdownを読み込む（Astro2変換バグ対策済）
const posts = import.meta.glob('./blog/*.md', { eager: true });
const allPosts = Object.values(posts) as any[];

// 2. 日付順にソート
const sortedPosts = allPosts.sort((a, b) => 
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);

// 3. ファイル名からスラッグを作る関数
const getSlug = (filePath: string) => filePath.split('/').pop()?.replace('.md', '');

// 4. 推奨記事と最新記事の切り分け（リスト側からも除外しない設定）
const featuredPost = sortedPosts.find(post => post.file.includes('concentration-tips'));
const otherPosts = sortedPosts.slice(0, 5);

const title = "地頭を鍛えて自分を使いこなす。知と実践のセルフマネジメント・ツール集";
const description = "知を学び、その場で試す。人間の仕組みを知り、地頭を鍛えて自分を使いこなすためのサイトです。";
---

<Layout title={title} description={description}>
	<header class="site-header">
		<div class="seo-tagline">FOR HIGH PERFORMANCE</div>
		<h1>🛠️ セルフマネジメント・ツール集</h1>
		<div class="top-description">
			<b>地頭を鍛えて、自分をもっと使いこなす。</b>
			知を学び、その場で試す。人間の仕組みを知り、地頭を鍛えて自分を使いこなす。気になる方法をパッと体験して、自分に合うものだけを取り入れ、日々のパフォーマンスを整えるツール集
		</div>
	</header>

	<main class="container">
		<section class="section-block">
			<h2 class="section-title">⚡ Try Now: すぐに実践する</h2>
			<div class="tool-grid">
				<a href="/besttimer/" class="tool-card">
					<div class="tool-header">
						<span class="tool-emoji">⏱️</span>
						<span class="tool-name">集中タイマー</span>
					</div>
					<span class="tool-desc">25分集中と休憩のサイクルで効率を維持します。</span>
					<span class="tool-tag">作業前に / 人気</span>
				</a>
				<a href="/zen/" class="tool-card">
					<div class="tool-header">
						<span class="tool-emoji">🧘</span>
						<span class="tool-name">瞑想タイマー</span>
					</div>
					<span class="tool-desc">呼吸に意識を向け、思考のノイズをリセット。</span>
					<span class="tool-tag">3分〜 / 疲労回復</span>
				</a>
				<a href="/n-back-calc/" class="tool-card">
					<div class="tool-header">
						<span class="tool-emoji">🧠</span>
						<span class="tool-name">N-Back計算</span>
					</div>
					<span class="tool-desc">ワーキングメモリを鍛え、対応力を向上させます。</span>
					<span class="tool-tag">脳トレ / 集中前に</span>
				</a>
				<a href="/memory-game/" class="tool-card">
					<div class="tool-header">
						<span class="tool-emoji">🃏</span>
						<span class="tool-name">記憶力トレーニング</span>
					</div>
					<span class="tool-desc">瞬間的な記憶を保持し、脳の処理速度を安定。</span>
					<span class="tool-tag">記憶 / リハビリ</span>
				</a>
			</div>
		</section>

		<section class="section-block">
			<h2 class="section-title">📚 Deep Dive: 知を深める</h2>
			
			{featuredPost && (
				<a href={`/blog/${getSlug(featuredPost.file)}/`} class="featured-article">
					<div class="featured-image">
						<img src={featuredPost.frontmatter.thumbnail} alt="" />
					</div>
					<div class="featured-content">
						<span class="featured-label">🔥 必読の集中テクニック</span>
						<h3 class="featured-title">{featuredPost.frontmatter.title}</h3>
						<p class="featured-desc">{featuredPost.frontmatter.description}</p>
					</div>
				</a>
			)}

			<div class="blog-list">
				{otherPosts.map(post => (
					<a href={`/blog/${getSlug(post.file)}/`} class="blog-item-link">
						<div class="item-thumb">
							<img src={post.frontmatter.thumbnail} alt="" />
						</div>
						<div class="item-info">
							<span class="item-date">{post.frontmatter.date}</span>
							<span class="item-title">{post.frontmatter.title}</span>
						</div>
					</a>
				))}
			</div>
			
			<a href="/blog/" class="view-all-btn">すべての記事を読む →</a>
		</section>
	</main>
</Layout>

<style>
	/* 基本レイアウト */
	.site-header { width: 100%; padding: 60px 20px 40px; text-align: center; box-sizing: border-box; }
	.seo-tagline { font-size: 0.8rem; font-weight: 800; color: #4f46e5; margin-bottom: 8px; letter-spacing: 0.2em; }
	.top-description { max-width: 600px; margin: 20px auto 0; font-size: 0.95rem; line-height: 1.8; color: #475569; }
	.top-description b { color: #0f172a; display: block; margin-bottom: 8px; font-size: 1.1rem; }
	.container { max-width: 700px; width: 95%; margin: 0 auto; padding-bottom: 80px; }
	.section-block { margin-bottom: 60px; }
	.section-title { font-size: 1.25rem; font-weight: 900; color: #0f172a; margin-bottom: 25px; border-left: 4px solid #4f46e5; padding-left: 15px; }

	/* ツールグリッド */
	.tool-grid { display: grid; grid-template-columns: 1fr; gap: 20px; }
	@media (min-width: 600px) { .tool-grid { grid-template-columns: repeat(2, 1fr); } }
	.tool-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 20px; padding: 20px; text-decoration: none; display: flex; flex-direction: column; transition: 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }
	.tool-card:hover { transform: translateY(-3px); box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); border-color: #4f46e5; }
	.tool-header { display: flex; align-items: center; margin-bottom: 10px; }
	.tool-emoji { font-size: 1.5rem; margin-right: 12px; }
	.tool-name { font-size: 1.05rem; font-weight: 800; color: #0f172a; }
	.tool-desc { font-size: 0.85rem; color: #64748b; line-height: 1.5; margin-bottom: 15px; flex-grow: 1; }
	.tool-tag { font-size: 0.7rem; font-weight: 700; color: #4f46e5; background: #f0f1ff; padding: 4px 12px; border-radius: 10px; align-self: flex-start; }

	/* 推奨記事（大きなカード） */
	.featured-article { background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%); border-radius: 24px; padding: 25px; text-decoration: none; display: block; margin-bottom: 25px; color: white; transition: 0.3s; overflow: hidden; }
	.featured-article:hover { transform: scale(1.01); box-shadow: 0 15px 30px -10px rgba(79, 70, 229, 0.5); }
	.featured-image { width: 100%; height: 200px; border-radius: 16px; overflow: hidden; margin-bottom: 15px; background: rgba(255,255,255,0.1); }
	.featured-image img { width: 100%; height: 100%; object-fit: cover; }
	.featured-label { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; opacity: 0.9; display: block; margin-bottom: 8px; }
	.featured-title { font-size: 1.3rem; font-weight: 800; margin: 0; line-height: 1.4; }
	.featured-desc { font-size: 0.9rem; margin-top: 10px; opacity: 0.9; line-height: 1.6; }

	/* 下の記事リスト（スッキリ横並び） */
	.blog-list { background: #fff; border-radius: 20px; border: 1px solid #e2e8f0; overflow: hidden; margin-bottom: 20px; }
	.blog-item-link { display: flex; align-items: center; padding: 16px 20px; text-decoration: none; color: #0f172a; border-bottom: 1px solid #f1f5f9; transition: background 0.2s; }
	.blog-item-link:last-child { border-bottom: none; }
	.blog-item-link:hover { background: #f8fafc; }

	.item-thumb { width: 60px; height: 60px; border-radius: 12px; overflow: hidden; flex-shrink: 0; background: #f1f5f9; margin-right: 16px; }
	.item-thumb img { width: 100%; height: 100%; object-fit: cover; }
	.item-info { flex-grow: 1; }
	.item-date { font-size: 0.75rem; color: #94a3b8; display: block; margin-bottom: 2px; }
	.item-title { font-size: 0.95rem; font-weight: 700; line-height: 1.4; color: #1e293b; }

	/* ボタン */
	.view-all-btn { display: block; text-align: center; font-size: 0.9rem; color: #475569; text-decoration: none; font-weight: 800; padding: 12px; border-radius: 20px; border: 1px solid #e2e8f0; transition: 0.2s; }
	.view-all-btn:hover { background: #0f172a; color: white; border-color: #0f172a; }
</style>