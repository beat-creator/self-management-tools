---
// src/pages/category/[category].astro
import Layout from '../../layouts/Layout.astro';

// 1. 存在するカテゴリのルートを定義（Astroの動的ルーティング仕様）
export async function getStaticPaths() {
  return [
    { params: { category: '集中力・時間管理' } },
    { params: { category: '思考法・記憶力' } },
    { params: { category: 'メンタルケア・セルフケア' } },
    { params: { category: 'ライフハック' } },
  ];
}

const { category } = Astro.params;

// 2. 競合バグの起きない安全な方法（import.meta.glob）でマークダウンを一括取得
const posts = import.meta.glob('../blog/*.md', { eager: true });
const allPosts = Object.values(posts) as any[];

// 3. 日付順にソート（新しい記事が上に来るように調整）
const parseDate = (dateStr: string) => {
  if (!dateStr) return 0;
  const match = dateStr.match(/(\d+)年(\d+)月(\d+)日/);
  if (match) {
    return new Date(parseInt(match[1]), parseInt(match[2]) - 1, parseInt(match[3])).getTime();
  }
  return new Date(dateStr).getTime();
};

const sortedPosts = allPosts.sort((a, b) => 
  parseDate(b.frontmatter.date) - parseDate(a.frontmatter.date)
);

// 4. フロントマターの category が、現在のURLのカテゴリと一致するものだけに絞り込む
const filteredPosts = sortedPosts.filter(post => post.frontmatter.category === category);

// 5. カテゴリに合わせた表示用のヘッダータイトルをマッピング
const categoryTitles = {
  '集中力・時間管理': '⏱️ 集中力・時間管理',
  '思考法・記憶力': '🧠 思考法・記憶力',
  'メンタルケア・セルフケア': '🧘 メンタルケア・セルフケア',
  'ライフハック': '⚡ ライフハック'
};
const displayTitle = categoryTitles[category] || category;
---

<Layout title={`${displayTitle}の記事一覧｜知と実践のセルフマネジメント`}>
  <main class="category-container">
    <header class="category-header">
      <nav class="breadcrumb">
        <a href="/">トップ</a> <span>&gt;</span> <span class="current">{displayTitle}</span>
      </nav>
      <h1>{displayTitle} のコラム一覧</h1>
      <p class="category-count">全 {filteredPosts.length} 件の記事</p>
    </header>

    <div class="post-list">
      {filteredPosts.length === 0 ? (
        <div class="no-posts">
          <p>このカテゴリの記事はまだありません。</p>
        </div>
      ) : (
        filteredPosts.map(post => (
          <article class="post-card">
            <a href={post.url} class="card-link">
              {post.frontmatter.thumbnail && (
                <div class="card-thumbnail">
                  <img src={post.frontmatter.thumbnail} alt={post.frontmatter.title} loading="lazy" />
                </div>
              )}
              <div class="card-content">
                <div class="card-meta">
                  <span class="card-date">{post.frontmatter.date}</span>
                  <span class="card-badge">{post.frontmatter.category}</span>
                </div>
                <h3>{post.frontmatter.title}</h3>
                <p class="card-description">{post.frontmatter.description}</p>
              </div>
            </a>
          </article>
        ))
      )}
    </div>
  </main>
</Layout>

<style>
  /* 既存のサイトデザインと調和するスコープ付きCSS */
  .category-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem 1rem;
  }
  
  .breadcrumb {
    font-size: 0.85rem;
    color: #6b7280;
    margin-bottom: 1rem;
  }
  .breadcrumb a {
    color: #3b82f6;
    text-decoration: none;
  }
  .breadcrumb a:hover {
    text-decoration: underline;
  }
  .breadcrumb span {
    margin: 0 0.5rem;
  }

  .category-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px solid #e5e7eb;
    padding-bottom: 1.5rem;
  }
  .category-header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 0.5rem 0;
  }
  .category-count {
    font-size: 0.9rem;
    color: #6b7280;
    margin: 0;
  }

  /* 🛠️ PC環境では横並びのリスト形式へ差し戻し */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* 白基調＋細グレー枠の洗練された配色を維持 */
  .post-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;       /* 上品なグレーの枠線 */
    border-radius: 12px;             /* 前と同じ角丸 */
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.03);
  }
  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08);
    border-color: #3b82f6;           /* ホバー時はテーマカラーの線に */
  }

  .card-link {
    display: flex;
    text-decoration: none;
    color: inherit;
    /* 💡前の占有率を再現するため、インナーマージンは持たせず、画像を端まで配置 */
  }
  @media (max-width: 640px) {
    .card-link {
      flex-direction: column;        /* スマホでは自動で縦型に */
    }
  }

  /* 🛠️ PC環境では画像を情報密度を邪魔しない適切なサイズ（固定幅）に戻す */
  .card-thumbnail {
    width: 200px;
    min-width: 200px;
    height: 130px;
    overflow: hidden;
    background: #f1f5f9;
  }

  /* 💡最強の打ち消しスタイルは、画像がどんな形でも白余白を作らないために継承 */
  .card-thumbnail img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: center !important;
    display: block !important;
    margin: 0 !important;
  }

  @media (max-width: 640px) {
    .card-thumbnail {
      width: 100%;
      height: 180px;                  /* スマホでは自動で大きく表示 */
    }
  }

  .card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex-grow: 1;
  }
  
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: #6b7280;
    margin-bottom: 0.5rem;
  }
  .card-badge {
    background: #eff6ff;
    color: #1e40af;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    font-weight: 500;
  }

  .card-content h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 0.5rem 0;
    line-height: 1.4;
  }
  .post-card:hover .card-content h3 {
    color: #3b82f6;
  }

  .card-description {
    font-size: 0.85rem;
    color: #4b5563;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;            /* 2行まで表示して綺麗に収める */
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .no-posts {
    text-align: center;
    padding: 4rem 1rem;
    color: #6b7280;
  }
</style>