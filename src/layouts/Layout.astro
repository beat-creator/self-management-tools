---
// 変数名を整理しました。これでエラーは消えます。
const { frontmatter, headings } = Astro.props;
const title = frontmatter?.title || Astro.props.title || "Self-Management Toolkit";
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>

		<script async src="https://www.googletagmanager.com/gtag/js?id=G-489DX1LV2M" is:inline></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-489DX1LV2M');
		</script>
	</head>
	<body>
		<main class="content-wrapper">
			{/* ここが「右側」でタイトルと目次を出すプログラムです */}
			{frontmatter && (
				<header class="post-header">
					<h1>{title}</h1>
					<p class="meta">公開日：{frontmatter.date} | カテゴリ：{frontmatter.category}</p>
				</header>

				<nav class="toc-container">
					<strong>目次</strong>
					<ul>
						{/* .md内の「##」を自動で拾ってリストにします */}
						{headings && headings.filter(h => h.depth <= 2).map((h) => (
							<li><a href={`#${h.slug}`}>{h.text}</a></li>
						))}
					</ul>
				</nav>
			)}

			<article class="post-body">
				<slot />
			</article>
		</main>

		<footer class="site-footer">
			<a href="/">トップページへ戻る</a>
			<p>© 2026 Self-Management Toolkit</p>
		</footer>
	</body>
</html>

<style is:global>
	/* デザインは維持 */
	body { font-family: sans-serif; line-height: 1.8; color: #333; background: #f9fbff; margin: 0; }
	.content-wrapper { max-width: 800px; margin: 0 auto; padding: 40px 20px; background: white; min-height: 100vh; }
	.post-header h1 { font-size: 2rem; color: #0f172a; text-align: center; margin-top: 0; }
	.meta { text-align: center; color: #64748b; font-size: 0.9rem; margin-bottom: 30px; }
	.toc-container { background: #fff; border: 1px solid #e2e8f0; padding: 20px; border-radius: 12px; margin-bottom: 40px; }
	.toc-container ul { padding-left: 20px; }
	.toc-container a { color: #4f46e5; text-decoration: none; }
	h2 { border-left: 5px solid #4f46e5; padding-left: 15px; margin-top: 50px; color: #1e293b; }
	.app-link-box { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: white; padding: 30px; border-radius: 16px; margin: 40px 0; text-align: center; }
	.app-link-box h4 { margin: 0 0 10px 0; color: white; }
	.app-link-box a { background: white !important; color: #4f46e5 !important; padding: 10px 20px; border-radius: 30px; text-decoration: none; font-weight: bold; display: inline-block; margin-top: 15px; }
	.site-footer { margin-top: 60px; padding: 40px 0; text-align: center; border-top: 1px solid #e2e8f0; }
	
	/* 画像のレスポンシブ対応とPCでのサイズ制限 */
	img {
		width: 100%;            /* スマホなど幅が狭い時は横幅いっぱい */
		max-width: 650px;      /* PCで見てもこれ以上大きくならない（本文幅に合わせる） */
		height: auto;           /* 比率を維持 */
		display: block;
		margin: 40px auto;      /* 上下に余白を作り、中央に寄せる */
		border-radius: 12px;    /* 角を丸くしてアプリの雰囲気に合わせる */
		box-shadow: 0 4px 20px rgba(0,0,0,0.05); /* 軽い影をつけて「図」として独立させる */
	}
/* --- 記事本文の画像最適化 --- */
article img {
  /* 1. スマホでは「横幅いっぱい」を基本にする */
  width: 100% !important; 
  max-width: 100% !important;
  height: auto !important;
  
  /* 2. 共通のデザイン設定 */
  display: block;
  margin: 30px auto;
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  /* スマホで縦長すぎないよう、少しだけ高さを制限（好みで調整） */
  max-height: 80vh; 
  object-fit: contain;
}

/* 3. PC（大きな画面）でのみ、巨大化を抑える */
@media (min-width: 769px) {
  article img {
    /* PCでは縦幅を固定して、横が縮むようにする */
    max-height: 500px;
    width: auto !important;
    margin: 40px auto;
  }
}}
</style>