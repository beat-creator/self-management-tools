---
// src/pages/category/[category].astro
import Layout from '../../layouts/Layout.astro';

// 1. 存在するカテゴリのルートを定義（Astroの動的ルーティング仕様）
export async function getStaticPaths() {
  return [
    { params: { category: '集中力・時間管理' } },
    { params: { category: '思考法・記憶力' } },
    { params: { category: 'メンタルケア・セルフケア' } },
    { params: { category: 'ライフハック' } },
  ];
}

const { category } = Astro.params;

// 2. 競合バグの起きない安全な方法（import.meta.glob）でマークダウンを一括取得
const posts = import.meta.glob('../blog/*.md', { eager: true });
const allPosts = Object.values(posts) as any[];

// 3. 日付順にソート（新しい記事が上に来るように調整）
const parseDate = (dateStr: string) => {
  if (!dateStr) return 0;
  const match = dateStr.match(/(\d+)年(\d+)月(\d+)日/);
  if (match) {
    return new Date(parseInt(match[1]), parseInt(match[2]) - 1, parseInt(match[3])).getTime();
  }
  return new Date(dateStr).getTime();
};

const sortedPosts = allPosts.sort((a, b) => 
  parseDate(b.frontmatter.date) - parseDate(a.frontmatter.date)
);

// 4. フロントマターの category が、現在のURLのカテゴリと一致するものだけに絞り込む
const filteredPosts = sortedPosts.filter(post => post.frontmatter.category === category);

// 5. カテゴリに合わせた表示用のヘッダータイトルをマッピング
const categoryTitles = {
  '集中力・時間管理': '⏱️ 集中力・時間管理',
  '思考法・記憶力': '🧠 思考法・記憶力',
  'メンタルケア・セルフケア': '🧘 メンタルケア・セルフケア',
  'ライフハック': '⚡ ライフハック'
};
const displayTitle = categoryTitles[category] || category;
---

<Layout title={`${displayTitle}の記事一覧｜知と実践のセルフマネジメント`}>
  <main class="category-container">
    <header class="category-header">
      <nav class="breadcrumb">
        <a href="/">トップ</a> <span>&gt;</span> <span class="current">{displayTitle}</span>
      </nav>
      <h1>{displayTitle} のコラム一覧</h1>
      <p class="category-count">全 {filteredPosts.length} 件の記事</p>
    </header>

    <div class="post-list">
      {filteredPosts.length === 0 ? (
        <div class="no-posts">
          <p>このカテゴリの記事はまだありません。</p>
        </div>
      ) : (
        filteredPosts.map(post => (
          <article class="post-card">
            <a href={post.url} class="card-link">
              {post.frontmatter.thumbnail && (
                <div class="card-thumbnail">
                  <img src={post.frontmatter.thumbnail} alt={post.frontmatter.title} loading="lazy" />
                </div>
              )}
              <div class="card-content">
                <div class="card-meta">
                  <span class="card-date">{post.frontmatter.date}</span>
                  <span class="card-badge">{post.frontmatter.category}</span>
                </div>
                <h3>{post.frontmatter.title}</h3>
                <p class="card-description">{post.frontmatter.description}</p>
              </div>
            </a>
          </article>
        ))
      )}
    </div>
  </main>
</Layout>

<style>
  /* 既存のサイトデザインと調和するスコープ付きCSS */
  .category-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem 1rem;
  }
  
  .breadcrumb {
    font-size: 0.85rem;
    color: #6b7280;
    margin-bottom: 1rem;
  }
  .breadcrumb a {
    color: #3b82f6;
    text-decoration: none;
  }
  .breadcrumb a:hover {
    text-decoration: underline;
  }
  .breadcrumb span {
    margin: 0 0.5rem;
  }

  .category-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px solid #e5e7eb;
    padding-bottom: 1.5rem;
  }
  .category-header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 0.5rem 0;
  }
  .category-count {
    font-size: 0.9rem;
    color: #6b7280;
    margin: 0;
  }

  /* 🛠️ ブログトップと統一感を持たせるグリッド配置（PC環境では2列） */
  .post-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
  }
  @media (min-width: 650px) {
    .post-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* 🛠️ 白基調 ＋ ゆったり美しいインナーマージンを持たせた縦型カード */
  .post-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;       /* 上品な薄グレーの枠線 */
    border-radius: 24px;             /* 豊かな角丸 */
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }
  .post-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    border-color: #3b82f6;
  }

  .card-link {
    display: flex;
    flex-direction: column;          /* 💡PC・スマホ両方で縦並びパネルに統一 */
    text-decoration: none;
    color: inherit;
    padding: 18px;                   /* 💡インナー余白であの美しい占有率を再現 */
    box-sizing: border-box;
    height: 100%;
  }

  /* 🛠️ サムネイル画像を枠の内側に綺麗に収める（16:9比率） */
  .card-thumbnail {
    width: 100% !important;
    min-width: 100% !important;
    aspect-ratio: 16 / 9;            /* 比率を16:9に美しく固定 */
    background: #f3f4f6;
    border-radius: 14px;             /* 💡画像の外周にも丸みを持たせて一体感を出す */
    overflow: hidden;
    margin-bottom: 16px;             /* 画像とテキストの間の余白 */
  }

  /* 💡最強の打ち消しスタイルをそのまま継承 */
  .card-thumbnail img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: center !important;
    display: block !important;
    margin: 0 !important;
  }

  .card-content {
    padding: 0;                      /* リンク側に余白を統合したため、ここは0にクリア */
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: #6b7280;
    margin-bottom: 0.5rem;
  }
  .card-badge {
    background: #eff6ff;
    color: #1e40af;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    font-weight: 500;
  }

  .card-content h3 {
    font-size: 1.05rem;
    font-weight: 800;
    color: #1f2937;
    margin: 0 0 10px 0;
    line-height: 1.4;
  }
  .post-card:hover .card-content h3 {
    color: #3b82f6;
  }

  .card-description {
    font-size: 0.85rem;
    color: #4b5563;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .no-posts {
    text-align: center;
    padding: 4rem 1rem;
    color: #6b7280;
  }

  /* スマホ画面用の調整 */
  @media (max-width: 480px) {
    .card-link { padding: 14px; }
    .post-card { border-radius: 20px; }
    .card-thumbnail { border-radius: 10px; margin-bottom: 12px; }
  }
</style>